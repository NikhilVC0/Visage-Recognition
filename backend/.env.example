# Visage Core MVP — Environment Configuration
# Copy this file to .env and customize values

# App
APP_NAME=Visage Core MVP
APP_VERSION=1.0.0
DEBUG=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./visage_attendance.db

# Authentication
SECRET_KEY=change-this-to-a-strong-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Face Recognition Thresholds & Settings
FACE_MODEL_DEVICE=auto
FACE_MATCH_THRESHOLD=0.45
FACE_DETECTION_CONFIDENCE=0.65
ANTI_SPOOF_THRESHOLD=0.55
MIN_FACE_SIZE=80

# Storage
UPLOAD_DIR=./uploads
FACE_IMAGES_DIR=./uploads/faces

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Default Admin Account
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_EMAIL=admin@visage.local
